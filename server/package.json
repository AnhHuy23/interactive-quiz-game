{
  "name": "interactive-quiz-api",
  "version": "1.0.0",
  "private": true,
  "description": "REST API for Interactive Quiz Game",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate:questions": "node scripts/generate-questions.mjs",
    "start": "node dist/index.js",
    "dev": "nodemon",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
